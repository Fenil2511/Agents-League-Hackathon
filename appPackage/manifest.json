{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.28/MicrosoftTeams.schema.json",
  "manifestVersion": "1.28",
  "version": "1.0.0",
  "id": "${{TEAMS_APP_ID}}",
  "developer": {
    "name": "CompliYUG",
    "websiteUrl": "https://example.com",
    "privacyUrl": "https://example.com/privacy",
    "termsOfUseUrl": "https://example.com/terms"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "name": {
    "short": "DPDP & ISO Compliance Copilot",
    "full": "DPDP Act & ISO Compliance Copilot Agent"
  },
  "description": {
    "short": "Monitors Microsoft 365 content for DPDP and ISO compliance risk.",
    "full": "An enterprise agent that helps governance teams detect PII risks, analyse compliance gaps against DPDP Act 2023 and ISO 27001:2022, generate audit-ready reports, and dispatch breach notifications."
  },
  "accentColor": "#0F5B78",
  "permissions": [
    "identity",
    "messageTeamMembers"
  ],
  "copilotAgents": {
    "declarativeAgents": [
      {
        "id": "complianceCopilotAgent",
        "file": "declarativeAgent.json"
      }
    ]
  },
  "validDomains": [
    "compliyug-api.azurewebsites.net",
    "compliyug-mcp.azurewebsites.net",
    "*.sharepoint.com"
  ],
  "webApplicationInfo": {
    "id": "395162df-1e6f-454b-9b3e-bbcb3587ff56",
    "resource": "api://compliyug-api.azurewebsites.net/395162df-1e6f-454b-9b3e-bbcb3587ff56"
  }
}